{
  "productName": "AstrCode",
  "version": "0.1.0",
  "identifier": "com.astrcode.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build"
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"],
    "targets": "all"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AstrCode",
        "width": 900,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  }
}
