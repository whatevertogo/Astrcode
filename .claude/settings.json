{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/pre-push-check.sh",
            "timeout": 300,
            "statusMessage": "Running pre-push checks..."
          }
        ]
      }
    ]
  }
}
